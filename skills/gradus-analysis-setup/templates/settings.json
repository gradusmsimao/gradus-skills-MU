{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "python -X utf8 \"$CLAUDE_PROJECT_DIR/.claude/hooks/path_guard.py\""
          },
          {
            "type": "command",
            "command": "python -X utf8 \"$CLAUDE_PROJECT_DIR/.claude/hooks/path_length_guard.py\""
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python -X utf8 \"$CLAUDE_PROJECT_DIR/.claude/hooks/destructive_guard.py\""
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit|NotebookEdit|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python -X utf8 \"$CLAUDE_PROJECT_DIR/.claude/hooks/audit.py\""
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python -X utf8 \"$CLAUDE_PROJECT_DIR/.claude/hooks/session_start.py\""
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python -X utf8 \"$CLAUDE_PROJECT_DIR/.claude/hooks/precompact_flush.py\""
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python -X utf8 \"$CLAUDE_PROJECT_DIR/.claude/hooks/stop_gate.py\""
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python -X utf8 \"$CLAUDE_PROJECT_DIR/.claude/hooks/cost_log.py\""
          }
        ]
      }
    ]
  }
}
